{
    "format_version": "1.8.0",
    "minecraft:attachable": {
        "description": {
            "identifier": "atomic:gloves",
            "item": {
                "atomic:gloves": "query.is_owner_identifier_any('minecraft:player')"
            },
            "materials": {
                "default": "armor",
                "enchanted": "armor_enchanted"
            },
            "textures": {
                "default": "textures/entity/glove_tex",
                "enchanted": "textures/misc/enchanted_item_glint"
            },
            "geometry": {
                "default": "geometry.gloves"
            },
            "animations": {
                "first_person": "animation.glove.first",
                "third_person": "animation.glove.third"
            },
            "scripts": {
                "animate": [
                    {
                        "first_person": "c.is_first_person"
                    },
                    {
                        "third_person": "c.is_first_person"
                    }
                ],
                "parent_setup": "v.chest_layer_visible = false;",
                "pre_animation": [
                    "variable.helmet_layer_visible = 0.0;"
                ]
            },
            "render_controllers": [
                "controller.render.armor"
            ]
        }
    }
}