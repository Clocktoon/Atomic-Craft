{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.vita": {
            "initial_state": "idle",
            "states": {
                "idle": { "animations": [ "idle" ], "transitions": [{ "walking": "query.ground_speed" }, { "attacking": "variable.attack_time >= 0.1" }]},
                "walking": { "animations": [ "walk" ], "transitions": [{ "idle": "!query.ground_speed" }, { "attacking": "variable.attack_time >= 0.1" }]},
                "attacking": { "animations": [ "attack" ], "transitions": [{ "idle": "variable.attack_time <= 0" }, { "walking": "variable.attack_time <= 0 && query.ground_speed" }]}
            }
        }
    }
}