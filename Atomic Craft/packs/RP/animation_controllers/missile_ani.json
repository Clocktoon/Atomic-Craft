{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.missile": {
			"initial_state": "idle",
			"states": {
				"idle": {
					"animations": [
						"idle"
					],
					"transitions": [
						{
							"falling": "!query.is_on_ground"
						}
					]
				},
				"falling": {
					"animations": [
						"moving"
					],
					"transitions": [
						{
							"idle": "query.is_on_ground"
						}
					]
				}
			}
		}
	}
}