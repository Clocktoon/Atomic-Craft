{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.plane": {
			"initial_state": "idley",
			"states": {
				"idley": {
					"animations": [
						"idley"
					],
					"transitions": [
						{
							"flying": "!query.is_on_ground"
						}
					]
				},
				"flying": {
					"animations": [
						"fly"
					],
					"transitions": [
						{
							"idley": "query.is_on_ground"
						}
					]
				}
			}
		}
	}
}