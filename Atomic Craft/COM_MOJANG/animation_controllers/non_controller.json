{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.non": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": [
                        "nonidle"
                    ],
                    "transitions": [
                        {
                            "flying": "!query.is_on_ground"
                        }
                    ]
                },
                "flying": {
                    "animations": [
                        "nonflying"
                    ],
                    "transitions": [
                        {
                            "idle": "query.is_on_ground"
                        }
                    ]
                }
            }
        } 
    }
}