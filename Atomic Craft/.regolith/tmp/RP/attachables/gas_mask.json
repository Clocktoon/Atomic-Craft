{
    "format_version": "1.21.100",
    "minecraft:attachable": {
        "description": {
            "identifier": "atomic:gas_mask",
            "item": {
                "atomic:gas_mask": "query.is_owner_identifier_any('minecraft:player')"
            },
            "materials": {
