            },
            "geometry": {
                "default": "geometry.gas_mask"
            },
            "scripts": {
                "pre_animation": [
                    "variable.helmet_layer_visible = 0.0;"
                ]
            },
            "render_controllers": [
                "controller.render.armor"
            ]
        }
    }
}