{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.himar_missile": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": [
                        "idlem"
                    ],
                    "transitions": [
                        {
                            "flyinginair": "!q.is_on_ground"
                        }
                    ]
                },
                "flyinginair": {
                    "animations": [
                        "flyinginair"
                    ],
                    "transitions": [
                        {
                            "idle": "q.is_on_ground"
                        }
                    ]
                }
            }
        }
    }
}